  phoneButton: {fileID: 1679299507}
  shiftPhoneMessages:
  - "\u0410\u043B\u043B\u043E? \u042D\u0442\u043E \u0414\u0438\u0441\u043F\u0435\u0442\u0447\u0435\u0440.
    \u0421\u043C\u0435\u043D\u0430 \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C.
    \u0422\u0432\u043E\u044F \u0437\u0430\u0434\u0430\u0447\u0430 \u043F\u0440\u043E\u0441\u0442\u0430:
    \u0441\u0432\u0435\u0440\u044F\u0439 \u0418\u041C\u042F \u0438 ID \u0432 \u043F\u0430\u0441\u043F\u043E\u0440\u0442\u0435
    \u0441 \u0431\u0430\u0437\u043E\u0439 \u0434\u0430\u043D\u043D\u044B\u0445 \u0432
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u0435. \u041D\u0435 \u0432\u043F\u0443\u0441\u043A\u0430\u0439
    \u0447\u0443\u0436\u0430\u043A\u043E\u0432. \u041A\u043E\u043D\u0435\u0446 \u0441\u0432\u044F\u0437\u0438."
  - "\u0412\u043D\u0438\u043C\u0430\u043D\u0438\u0435! \u0412 \u0433\u043E\u0440\u043E\u0434\u0435
    \u0443\u0447\u0430\u0441\u0442\u0438\u043B\u0438\u0441\u044C \u0441\u043B\u0443\u0447\u0430\u0438
    \u043F\u043E\u0434\u0434\u0435\u043B\u043A\u0438 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u043E\u0432.
    \u0422\u0435\u043F\u0435\u0440\u044C \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u0439
    \u0435\u0449\u0435 \u0438 \u0426\u0412\u0415\u0422 \u0413\u041B\u0410\u0417.
    \u0415\u0441\u043B\u0438 \u043D\u0435 \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u0435\u0442
    \u2014 \u0436\u043C\u0438 \u043E\u0442\u043A\u0430\u0437. \u0411\u0443\u0434\u044C
    \u0431\u0434\u0438\u0442\u0435\u043B\u0435\u043D."
  - "\u0421\u043B\u0443\u0448\u0430\u0439 \u0432\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u043E.
    \u041C\u043E\u043D\u0441\u0442\u0440\u044B \u043A\u0440\u0430\u0434\u0443\u0442
    \u0441\u0442\u0430\u0440\u044B\u0435 \u043F\u0430\u0441\u043F\u043E\u0440\u0442\u0430.
    \u0422\u0435\u043F\u0435\u0440\u044C \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u0439 \u0421\u0420\u041E\u041A \u0414\u0415\u0419\u0421\u0422\u0412\u0418\u042F.
    \u0415\u0441\u043B\u0438 \u043F\u0440\u043E\u0441\u0440\u043E\u0447\u0435\u043D
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u0447\u0435\u043B\u043E\u0432\u0435\u043A.
    \u0423\u0434\u0430\u0447\u0438."
  - "\u042D\u0442\u043E \u0442\u0432\u043E\u044F \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u044F\u044F
    \u0441\u043C\u0435\u043D\u0430. \u041E\u043D\u0438 \u043F\u043E\u043F\u044B\u0442\u0430\u044E\u0442\u0441\u044F
    \u043F\u0440\u043E\u0440\u0432\u0430\u0442\u044C\u0441\u044F. \u0423\u0434\u0430\u0447\u0438."
