  passportName: "\u0421\u0415\u0420\u0413\u0415\u0419 \u0421\u041A\u0415\u041B\u0415\u0422\u041E\u0412"
  passportId: 13-13-13
  passportEyes: "\u041A\u0410\u0420\u0418\u0415"
  passportExpDate: 1989-12-31
  isMonster: 1
  isImpatient: 0
  isMimic: 0
  welcomeSpeech: "\u0414\u043E\u0431\u0440\u044B\u0439 \u0432\u0435\u0447\u0435\u0440,
    \u0442\u043E\u0432\u0430\u0440\u0438\u0449 \u0434\u0435\u0436\u0443\u0440\u043D\u044B\u0439.
    \u042F \u043F\u0440\u043E\u0441\u0442\u043E \u0448\u0435\u043B \u043C\u0438\u043C\u043E
    \u0432 \u0430\u0440\u0445\u0438\u0432. \u042F \u043E\u0431\u044B\u0447\u043D\u044B\u0439
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A, \u0447\u0435\u0441\u0442\u043D\u043E."
  responseName: "\u0414\u0430, \u0421\u0435\u0440\u0433\u0435\u0439 \u0421\u043A\u0435\u043B\u0435\u0442\u043E\u0432.
    \u0420\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u0438 \u0442\u043E\u0436\u0435
    \u0421\u043A\u0435\u043B\u0435\u0442\u043E\u0432\u044B."
  responseEyes: "\u0413\u043B\u0430\u0437\u0430? \u041F\u0440\u043E\u0441\u0442\u043E
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0435 \u0433\u043B\u0430\u0437\u043D\u0438\u0446\u044B,
    \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u0435 \u044D\u0442\u043E \u0443 \u043D\u0430\u0441..."
  responseDate: "\u041F\u0430\u0441\u043F\u043E\u0440\u0442 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439,
    \u0434\u0430\u0436\u0435 \u043A\u043E\u0436\u0430\u043D\u044B\u0439 \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442...
    \u041E\u0439, \u043A\u043E\u0436\u0438 \u0443 \u043C\u0435\u043D\u044F \u043D\u0435\u0442,
    \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442 \u0431\u0443\u043C\u0430\u0436\u043D\u044B\u0439."
