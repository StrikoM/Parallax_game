  isImpatient: 1
  isMimic: 0
  welcomeSpeech: "\u041E\u0439, \u0441\u044B\u043D\u043E\u0447\u0435\u043A, \u0441\u043E\u0432\u0441\u0435\u043C
    \u0437\u0430\u043C\u0435\u0440\u0437\u043B\u0430 \u0441\u0442\u043E\u044F\u0442\u044C
    \u0443 \u0432\u043E\u0440\u043E\u0442 \u0431\u0443\u043D\u043A\u0435\u0440\u0430...
    \u0412\u043F\u0443\u0441\u0442\u0438 \u0441\u0442\u0430\u0440\u0443\u044E \u0431\u0430\u0431\u0443\u0448\u043A\u0443
    \u0447\u0430\u0439\u043A\u0443 \u043F\u043E\u043F\u0438\u0442\u044C..."
  responseName: "\u0418\u043C\u044F \u0442\u043E \u043C\u043E\u0435, \u0417\u0438\u043D\u0430
    \u044F, \u0417\u0438\u043D\u0430\u0438\u0434\u0430 \u041F\u0435\u0442\u0440\u043E\u0432\u043D\u0430!"
  responseEyes: "\u0414\u0430 \u044D\u0442\u043E \u043E\u0442 \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0433\u043B\u0430\u0437\u0430 \u043F\u0440\u0438\u043F\u0443\u0445\u043B\u0438
    \u0438 \u043F\u043E\u043A\u0440\u0430\u0441\u043D\u0435\u043B\u0438, \u0441\u044B\u043D\u043E\u043A...
    \u0412\u0440\u0430\u0447\u0438 \u0433\u043E\u0432\u043E\u0440\u044F\u0442, \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u043D\u043E\u0435
    \u044D\u0442\u043E..."
  responseDate: "\u0421\u0440\u043E\u043A \u0433\u043E\u0434\u043D\u043E\u0441\u0442\u0438?
    \u0414\u0430 \u0433\u043E\u0434\u0435\u043D \u0435\u0449\u0435 \u043F\u0430\u0441\u043F\u043E\u0440\u0442,
    \u0441\u044B\u043D\u043E\u043A, \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0441\u043C\u0435\u043D\u044B
    \u0442\u043E\u0447\u043D\u043E..."
